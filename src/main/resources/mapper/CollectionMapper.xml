<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 收藏Mapper XML映射文件 -->
<mapper namespace="com.codevault.mapper.CollectionMapper">

    <!-- 结果映射：将数据库字段映射到Collection实体类属性 -->
    <resultMap id="collectionResultMap" type="com.codevault.entity.Collection">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="snippetId" column="snippet_id"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <!-- 片段结果映射（用于收藏列表查询） -->
    <resultMap id="snippetResultMap" type="com.codevault.entity.Snippet">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="content" column="content"/>
        <result property="language" column="language"/>
        <result property="categoryId" column="category_id"/>
        <result property="viewCount" column="view_count"/>
        <result property="likeCount" column="like_count"/>
        <result property="collectCount" column="collect_count"/>
        <result property="isPublic" column="is_public"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 新增收藏记录 -->
    <insert id="insert" parameterType="com.codevault.entity.Collection" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO collection (user_id, snippet_id, create_time)
        VALUES (#{userId}, #{snippetId}, #{createTime})
    </insert>

    <!-- 查询用户是否已收藏指定片段 -->
    <select id="findByUserAndSnippet" resultMap="collectionResultMap">
        SELECT id, user_id, snippet_id, create_time
        FROM collection
        WHERE user_id = #{userId} AND snippet_id = #{snippetId}
    </select>

    <!-- 取消收藏 -->
    <delete id="deleteByUserAndSnippet">
        DELETE FROM collection
        WHERE user_id = #{userId} AND snippet_id = #{snippetId}
    </delete>

    <!-- 查询用户已收藏的片段ID列表 -->
    <select id="findCollectedSnippetIds" parameterType="java.lang.Long" resultType="java.lang.Long">
        SELECT snippet_id FROM collection
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>

    <!-- 分页查询用户的收藏列表（关联snippet表获取片段详情） -->
    <select id="findUserCollections" resultMap="snippetResultMap">
        SELECT s.id, s.user_id, s.title, s.description, s.content, s.language, s.category_id,
               s.view_count, s.like_count, s.collect_count, s.is_public, s.status,
               s.create_time, s.update_time
        FROM snippet s
        INNER JOIN collection c ON s.id = c.snippet_id
        WHERE c.user_id = #{userId} AND s.status = 1
        ORDER BY c.create_time DESC
        LIMIT #{offset}, #{pageSize}
    </select>

    <!-- 统计用户的收藏总数 -->
    <select id="countUserCollections" parameterType="java.lang.Long" resultType="int">
        SELECT COUNT(*)
        FROM collection c
        INNER JOIN snippet s ON c.snippet_id = s.id
        WHERE c.user_id = #{userId} AND s.status = 1
    </select>

</mapper>
