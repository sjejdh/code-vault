<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 分类Mapper XML映射文件 -->
<mapper namespace="com.codevault.mapper.CategoryMapper">

    <!-- 结果映射：将数据库字段映射到Category实体类属性 -->
    <resultMap id="categoryResultMap" type="com.codevault.entity.Category">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="icon" column="icon"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="baseColumns">
        id, name, icon, sort_order, create_time
    </sql>

    <!-- 查询所有分类，按sort_order升序排列 -->
    <select id="findAll" resultMap="categoryResultMap">
        SELECT <include refid="baseColumns"/>
        FROM category
        ORDER BY sort_order ASC
    </select>

    <!-- 根据ID查询分类 -->
    <select id="findById" parameterType="java.lang.Long" resultMap="categoryResultMap">
        SELECT <include refid="baseColumns"/>
        FROM category
        WHERE id = #{id}
    </select>

    <!-- 新增分类 -->
    <insert id="insert" parameterType="com.codevault.entity.Category" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category (name, icon, sort_order)
        VALUES (#{name}, #{icon}, #{sortOrder})
    </insert>

    <!-- 更新分类信息（动态SQL，只更新非空字段） -->
    <update id="update" parameterType="com.codevault.entity.Category">
        UPDATE category
        <set>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据ID删除分类 -->
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM category WHERE id = #{id}
    </delete>

</mapper>
